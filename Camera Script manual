    void HandleLook()
    {
#if ENABLE_INPUT_SYSTEM
        Mouse mouse = Mouse.current;
        if (mouse != null && mouse.leftButton.isPressed)
        {
            if (!isLooking)
            {
                Cursor.lockState = CursorLockMode.Locked;
                Cursor.visible = false;
                isLooking = true;
            }
            Vector2 delta = mouse.delta.ReadValue();
            transform.Rotate(Vector3.up, delta.x * lookSensitivity * 0.1f, Space.World);
            transform.Rotate(Vector3.right, -delta.y * lookSensitivity * 0.1f, Space.Self);
        }
        else if (isLooking)
        {
            Cursor.lockState = CursorLockMode.None;
            Cursor.visible = true;
            isLooking = false;
        }
#else
        if (Input.GetMouseButton(1))
        {
            transform.Rotate(Vector3.up, Input.GetAxis("Mouse X") * lookSensitivity, Space.World);
            transform.Rotate(Vector3.right, -Input.GetAxis("Mouse Y") * lookSensitivity, Space.Self);
        }
#endif
    }

    void HandleMovement()
    {
        bool accelerating = false;
        bool decelerating = false;
        bool stopping = false;
        int presetIndex = -1;

#if ENABLE_INPUT_SYSTEM
        Keyboard kb = Keyboard.current;
        if (kb != null)
        {
            if (kb.wKey.isPressed || kb.upArrowKey.isPressed)   accelerating = true;
            if (kb.sKey.isPressed || kb.downArrowKey.isPressed) decelerating = true;
            if (kb.spaceKey.wasPressedThisFrame)                stopping = true;

            if      (kb.digit1Key.isPressed) presetIndex = 0;
            else if (kb.digit2Key.isPressed) presetIndex = 1;
            else if (kb.digit3Key.isPressed) presetIndex = 2;
            else if (kb.digit4Key.isPressed) presetIndex = 3;
            else if (kb.digit5Key.isPressed) presetIndex = 4;
            else if (kb.digit6Key.isPressed) presetIndex = 5;
            else if (kb.digit7Key.isPressed) presetIndex = 6;
            else if (kb.digit8Key.isPressed) presetIndex = 7;
            else if (kb.digit9Key.isPressed) presetIndex = 8;
        }
#else
        if (Input.GetKey(KeyCode.W) || Input.GetKey(KeyCode.UpArrow))   accelerating = true;
        if (Input.GetKey(KeyCode.S) || Input.GetKey(KeyCode.DownArrow)) decelerating = true;
        if (Input.GetKeyDown(KeyCode.Space))                             stopping = true;

        for (int i = 0; i < 9; i++)
        {
            if (Input.GetKey(KeyCode.Alpha1 + i))
            {
                presetIndex = i;
                break;
            }
        }
#endif

        if (stopping)
        {
            currentSpeed = 0f;
            targetSpeed = null;
            return;
        }

        if (accelerating || decelerating)
            targetSpeed = null;

        if (presetIndex >= 0)
            targetSpeed = velocityPresets[presetIndex];

        if (targetSpeed.HasValue)
        {
            float diff = targetSpeed.Value - currentSpeed;
            float step = (diff > 0 ? acceleration : deceleration) * Time.deltaTime;

            if (Mathf.Abs(diff) <= step)
            {
                currentSpeed = targetSpeed.Value;
                targetSpeed = null;
            }
            else
            {
                currentSpeed += Mathf.Sign(diff) * step;
            }
        }
        else if (accelerating)
        {
            currentSpeed += acceleration * Time.deltaTime;
            currentSpeed = Mathf.Min(currentSpeed, 0.9999f);
        }
        else if (decelerating)
        {
            currentSpeed -= deceleration * Time.deltaTime;
            currentSpeed = Mathf.Max(currentSpeed, 0f);
        }
    }

    void ApplyMovement()
    {
        transform.position += Vector3.forward * currentSpeed * Time.deltaTime * movementScale;
    }
    
