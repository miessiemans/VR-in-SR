using UnityEngine;

public class RelativisticCameraURP : MonoBehaviour
{
    [Header("Speed Settings")]
    [SerializeField] private float acceleration = 0.3f;
    [SerializeField] private float deceleration = 0.3f;
    [SerializeField] private float movementScale = 0f;

    [Header("FOV Settings")]
    [SerializeField] private float displayFOV = 90f;

    [Header("Starting Speed")]
    [SerializeField] private float currentSpeed = 0f;

    [Header("360 Capture")]
    [SerializeField] private int cubemapSize = 1024;
    [SerializeField] private int cubemapCaptureInterval = 4; // capture every N frames

    [Header("Look Settings")]
    [SerializeField] private float lookSensitivity = 2f;

    // Thumbstick deadzone
    private const float DEADZONE = 0.15f;


    private readonly float[] velocityPresets = new float[]
    {
        0.1f, 
        0.3f, 
        0.5f, 
        0.7f, 
        0.9f  
    };

    private float? targetSpeed = null;
    private bool isLooking = false;
    private int cubemapFrameCounter = 0;
    private float smoothedDeltaTime = 0f;

    private Camera cam;
    private Camera captureCamera;
    private RenderTexture cubemapRT;
    private RenderTexture equirectRT;

    public float SpeedFraction => Mathf.Abs(currentSpeed);
    public Vector3 VelocityDirection => currentSpeed >= 0 ? Vector3.forward : Vector3.back;
    public float DisplayFOV => displayFOV;
    public RenderTexture EquirectTexture => equirectRT;

    void Start()
    {
        OVRPlugin.systemDisplayFrequency = 72f;
        UnityEngine.XR.XRSettings.eyeTextureResolutionScale = 1.0f;
        Camera.main.stereoTargetEye = StereoTargetEyeMask.None;
        cam = GetComponent<Camera>();
        if (cam == null)
            cam = Camera.main;
        cam.fieldOfView = displayFOV;


        GameObject captureGO = new GameObject("CubemapCaptureCamera");
        captureGO.transform.SetParent(transform.parent);
        captureCamera = captureGO.AddComponent<Camera>();
        captureCamera.CopyFrom(cam);
        captureCamera.enabled = false;

        cubemapRT = new RenderTexture(cubemapSize, cubemapSize, 16);
        cubemapRT.dimension = UnityEngine.Rendering.TextureDimension.Cube;
        cubemapRT.Create();

        equirectRT = new RenderTexture(cubemapSize * 2, cubemapSize, 0);
        equirectRT.Create();


        CaptureScene();
    }

    void Update()
    {

        if (!UnityEngine.XR.XRSettings.isDeviceActive)
        {
            HandleMouseLook();
            HandleKeyboardInput();
        }

        HandleControllerInput();
        ApplyMovement();
    }

    void LateUpdate()
    {

        cubemapFrameCounter++;
        if (cubemapFrameCounter >= cubemapCaptureInterval)
        {
            cubemapFrameCounter = 0;
            CaptureScene();
        }
    }

    void CaptureScene()
    {

        captureCamera.transform.position = transform.position;
        captureCamera.transform.rotation = Quaternion.LookRotation(VelocityDirection, Vector3.up);
        captureCamera.RenderToCubemap(cubemapRT);
        cubemapRT.ConvertToEquirect(equirectRT, Camera.MonoOrStereoscopicEye.Mono);
    }

    void HandleMouseLook()
    {
        if (Input.GetMouseButton(1))
        {
            if (!isLooking)
            {
                Cursor.lockState = CursorLockMode.Locked;
                Cursor.visible = false;
                isLooking = true;
            }
            transform.Rotate(Vector3.up, -Input.GetAxis("Mouse X") * lookSensitivity, Space.World);
            transform.Rotate(Vector3.right, -Input.GetAxis("Mouse Y") * lookSensitivity, Space.Self);
        }
        else if (isLooking)
        {
            Cursor.lockState = CursorLockMode.None;
            Cursor.visible = true;
            isLooking = false;
        }
    }

    void HandleKeyboardInput()
    {
        if (Input.GetKey(KeyCode.W) || Input.GetKey(KeyCode.UpArrow))
        {
            targetSpeed = null;
            currentSpeed += acceleration * Time.deltaTime;
            currentSpeed = Mathf.Min(currentSpeed, 0.9999f);
        }
        else if (Input.GetKey(KeyCode.S) || Input.GetKey(KeyCode.DownArrow))
        {
            targetSpeed = null;
            currentSpeed -= deceleration * Time.deltaTime;
            currentSpeed = Mathf.Max(currentSpeed, 0f);
        }

        if (Input.GetKeyDown(KeyCode.Space))
        {
            currentSpeed = 0f;
            targetSpeed = null;
        }

        for (int i = 0; i < velocityPresets.Length; i++)
        {
            if (Input.GetKeyDown(KeyCode.Alpha1 + i))
            {
                targetSpeed = velocityPresets[i];
                break;
            }
        }
    }

    void HandleControllerInput()
    {

        Vector2 leftStick = OVRInput.Get(OVRInput.Axis2D.PrimaryThumbstick, OVRInput.Controller.LTouch);
        if (Mathf.Abs(leftStick.x) > DEADZONE || Mathf.Abs(leftStick.y) > DEADZONE)
        {
            transform.Rotate(Vector3.up, -leftStick.x * lookSensitivity * 2f, Space.World);
            transform.Rotate(Vector3.right, leftStick.y * lookSensitivity * 2f, Space.Self);
        }


        float rightStickY = OVRInput.Get(OVRInput.Axis2D.PrimaryThumbstick, OVRInput.Controller.RTouch).y;
        if (Mathf.Abs(rightStickY) > DEADZONE)
        {
            targetSpeed = null;
            if (rightStickY > 0)
            {
                currentSpeed += acceleration * rightStickY * Time.deltaTime;
                currentSpeed = Mathf.Min(currentSpeed, 0.9999f);
            }
            else
            {
                currentSpeed += deceleration * rightStickY * Time.deltaTime;
                currentSpeed = Mathf.Max(currentSpeed, 0f);
            }
        }


        if (OVRInput.GetDown(OVRInput.Button.PrimaryIndexTrigger, OVRInput.Controller.RTouch))
        {
            currentSpeed = 0f;
            targetSpeed = null;
        }


        if (OVRInput.GetDown(OVRInput.Button.Three, OVRInput.Controller.LTouch))                      
            targetSpeed = velocityPresets[0];
        else if (OVRInput.GetDown(OVRInput.Button.Four, OVRInput.Controller.LTouch))                 
            targetSpeed = velocityPresets[1];
        else if (OVRInput.GetDown(OVRInput.Button.PrimaryThumbstick, OVRInput.Controller.LTouch))      
            targetSpeed = velocityPresets[2];
        else if (OVRInput.GetDown(OVRInput.Button.PrimaryThumbstick, OVRInput.Controller.RTouch))      
            targetSpeed = velocityPresets[3];
        else if (OVRInput.GetDown(OVRInput.Button.One, OVRInput.Controller.RTouch))                    
            targetSpeed = velocityPresets[4];

        // --- Smooth transition to preset target ---
        if (targetSpeed.HasValue)
        {
            float diff = targetSpeed.Value - currentSpeed;
            float step = (diff > 0 ? acceleration : deceleration) * Time.deltaTime;

            if (Mathf.Abs(diff) <= step)
            {
                currentSpeed = targetSpeed.Value;
                targetSpeed = null;
            }
            else
            {
                currentSpeed += Mathf.Sign(diff) * step;
            }
        }
    }

    void ApplyMovement()
    {
        transform.position += VelocityDirection * currentSpeed * Time.deltaTime * movementScale;
    }

    private float fpsAccumulator = 0f;
    private int fpsFrameCount = 0;
    private float fpsAverage = 0f;
    private const float fpsAveragePeriod = 2f; 

    void OnGUI()
    {
        // Speed display
        GUIStyle style = new GUIStyle(GUI.skin.label)
        {
            fontSize = 48,
            fontStyle = FontStyle.Bold,
            alignment = TextAnchor.MiddleCenter
        };
        style.normal.textColor = new Color(1f, 0.8f, 0.2f);

        float spd = Mathf.Abs(currentSpeed);
        string label = targetSpeed.HasValue
            ? $"{spd:F3}c  →  {targetSpeed.Value:F1}c"
            : $"{spd:F3}c";
        GUI.Label(new Rect(0, Screen.height - 200, Screen.width, 60), label, style);

        // FPS counter — smoothed to avoid per-frame jitter
        smoothedDeltaTime = Mathf.Lerp(smoothedDeltaTime, Time.deltaTime, 0.1f);
        int fps = Mathf.RoundToInt(1f / smoothedDeltaTime);
        GUIStyle fpsStyle = new GUIStyle(GUI.skin.label)
        {
            fontSize = 32,
            fontStyle = FontStyle.Bold,
            alignment = TextAnchor.UpperLeft
        };

        fpsStyle.normal.textColor = fps >= 60 ? Color.green : fps >= 30 ? Color.yellow : Color.red;
        GUI.Label(new Rect(10, 10, 200, 50), $"{fps} FPS", fpsStyle);
                
        fpsAccumulator += 1f / Time.deltaTime;
        fpsFrameCount++;
        if (fpsFrameCount * Time.deltaTime >= fpsAveragePeriod)
        {
            fpsAverage = fpsAccumulator / fpsFrameCount;
            fpsAccumulator = 0f;
            fpsFrameCount = 0;
        }

        GUIStyle avgStyle = new GUIStyle(GUI.skin.label)
        {
            fontSize = 32,
            fontStyle = FontStyle.Bold,
            alignment = TextAnchor.UpperRight
        };
        avgStyle.normal.textColor = new Color(0.6f, 0.8f, 1f);
        GUI.Label(new Rect(Screen.width - 250, 10, 240, 50), $"Avg: {fpsAverage:F0} FPS", avgStyle);
    }

    void OnDestroy()
    {
        if (cubemapRT != null) cubemapRT.Release();
        if (equirectRT != null) equirectRT.Release();
        if (cam != null) cam.fieldOfView = displayFOV;
        Cursor.lockState = CursorLockMode.None;
        Cursor.visible = true;
    }
}
